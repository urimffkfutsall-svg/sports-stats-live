export interface Season {
  id: string;
  name: string;
  startDate: string;
  endDate: string;
  isActive: boolean;
}

export type CompetitionType = 'superliga' | 'liga_pare' | 'kupa';

export interface Competition {
  id: string;
  name: string;
  type: CompetitionType;
  seasonId: string;
  isActiveLanding: boolean;
}

export interface Team {
  id: string;
  name: string;
  logo: string;
  competitionId: string;
  seasonId: string;
  foundedYear?: string;
  stadium?: string;

  city?: string;}

